{
  "name": "md2pdf",
  "version": "1.0.4",
  "private": false,
  "description": "Markdown to ГОСТ-style PDF converter with Mermaid support.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "markdown",
    "pdf",
    "gost",
    "mermaid"
  ],
  "scripts": {
    "pdf": "PYTHONPATH=src python3 -m md2pdf README.md README.pdf",
    "example": "PYTHONPATH=src python3 -m md2pdf examples/example.md examples/example.pdf",
    "pdf:strict": "PYTHONPATH=src python3 -m md2pdf README.md README.pdf --strict-mermaid",
    "example:strict": "PYTHONPATH=src python3 -m md2pdf examples/example.md examples/example.pdf --strict-mermaid",
    "lint": "python3 -m ruff check .",
    "test": "python3 -m pytest -q",
    "dist": "python3 -m build",
    "check": "npm run lint && npm run test && npm run pdf && npm run example",
    "check:strict": "npm run lint && npm run test && npm run pdf:strict && npm run example:strict"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.14.0"
  }
}
